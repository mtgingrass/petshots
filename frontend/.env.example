# Copy this file to .env and fill in real values.
# These are PUBLIC client identifiers (they ship in the browser bundle), not secrets.
# Fetch the real values any time with:
#   aws cloudformation describe-stacks --stack-name PetshotsAuthStack --query 'Stacks[0].Outputs'

VITE_AWS_REGION=us-east-1
VITE_COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# Base URL of PetshotsApiStack HTTP API (cdk output ApiUrl). Not a secret.
VITE_API_BASE_URL=https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com
